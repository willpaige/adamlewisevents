# Postgres connection (Neon pooled URL)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Payload secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Server URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# First admin user for seed script (only used on first seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# Vercel Blob (Storage → Blob → connect to project; copy the read/write token)
# In production, set this on Vercel. Local dev works without it (Payload falls
# back to local filesystem under /media).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
